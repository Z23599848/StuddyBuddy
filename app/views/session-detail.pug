extends layout

block content
  .session-detail
    h1= session.topic
    p Location: #{session.location || 'Location TBD'}
    p Date: #{new Date(session.scheduled_time).toLocaleString()}
    p Organised by
      a(href="/users/" + session.creator_id)  #{session.first_name} #{session.last_name}
    p Max Participants: #{session.max_participants || 'Unlimited'}

  section
    h2 Participants
    if participants.length
      ul.plain-list
        each participant in participants
          li
            a(href="/users/" + participant.user_id)= participant.first_name + ' ' + participant.last_name
            span  - #{participant.status}
    else
      p No participants yet.

  if currentUser && rateableUsers.length
    section.form-panel
      h2 Rate a Completed Session
      form(action="/sessions/" + session.session_id + "/ratings" method="post")
        .form-grid
          label
            span Student
            select(name="rated_user_id" required)
              option(value="") Choose student
              each student in rateableUsers
                option(value=student.user_id)= student.first_name + ' ' + student.last_name
          label
            span Rating
            select(name="score" required)
              option(value="") Choose rating
              option(value="5") 5 - Excellent
              option(value="4") 4 - Good
              option(value="3") 3 - OK
              option(value="2") 2 - Needs work
              option(value="1") 1 - Poor
        label.full-width
          span Feedback
          textarea(name="feedback" rows="3")
        button.btn(type="submit") Save Rating

  section
    h2 Session Ratings
    if sessionRatings.length
      .review-list
        each rating in sessionRatings
          .review-card
            strong #{rating.score} / 5
            span  for #{rating.rated_first_name} #{rating.rated_last_name} by #{rating.reviewer_first_name} #{rating.reviewer_last_name}
            if rating.feedback
              p= rating.feedback
    else
      p No ratings for this session yet.

  a.btn(href="/sessions") Back to Sessions
