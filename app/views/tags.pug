extends layout

block content
  h1 Browse by Topic
  p Click a topic to filter study sessions.

  if currentUser
    form.form-panel.narrow-form(action="/tags" method="post")
      label
        span Create a topic
        input(type="text" name="topic_name" maxlength="255" required)
      button.btn(type="submit") Add Topic
  else
    p
      a(href="/login") Log in
      |  to create a new topic.

  .tag-grid
    each tag in tags
      a.tag-pill(href="/sessions?tag=" + encodeURIComponent(tag.tag))
        span.tag-name= tag.tag
        span.tag-count  (#{tag.total})
